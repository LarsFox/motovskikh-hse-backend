{
  "swagger": "2.0",
  "info": {
    "title": "Motovskikh Tests API",
    "description": "API для системы трекинга рекордов с детальным анализом",
    "version": "2.0.0"
  },
  "host": "localhost:8080",
  "basePath": "/",
  "schemes": ["http"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "paths": {
    "/tests/get/": {
      "get": {
        "summary": "Получить тест для прохождения",
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "test_name",
            "in": "query",
            "required": true,
            "type": "string",
            "description": "Name теста"
          }
        ],
        "responses": {
          "200": {
            "description": "Информация о тесте",
            "schema": {
              "type": "object",
              "properties": {
                "ok": {"type": "boolean"},
                "result": {"type": "object"}
              }
            }
          },
          "404": {
            "description": "Тест не найден",
            "schema": {
              "type": "object",
              "properties": {
                "ok": {"type": "boolean", "example": false},
                "error": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "/tests/submit/": {
      "post": {
        "summary": "Отправить ответы на тест",
        "description": "Сохраняет попытку",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "test_name": {"type": "string"},
                "percentage": {"type": "integer"},
                "time_spent": { "type": "integer"}
              },
              "required": ["test_id", "answers", "time_spent"]
            }
          },
          {
            "name": "User-Hash",
            "in": "header",
            "required": false,
            "type": "string",
            "description": "Хэш пользователя (если нет - генерируется автоматически)"
          }
        ],
        "responses": {
          "200": {
            "description": "Результат теста с анализом",
            "schema": {
              "type": "object",
              "properties": {
                "ok": {"type": "boolean"},
                "result": {
                  "type": "object",
                  "properties": {
                    "attempt_id": {"type": "string"},
                    "score": {"type": "integer"},
                    "max_score": {"type": "integer"},
                    "percentage": {"type": "number", "format": "float"},
                    "time_spent": {"type": "integer"},
                    "is_valid": {"type": "boolean"},
                    "analysis": {"type": "object"},
                    "answers_details": {"type": "object"}
                  }
                }
              }
            }
          },
          "400": {
            "description": "Неверные параметры",
            "schema": {
              "type": "object",
              "properties": {
                "ok": {"type": "boolean", "example": false},
                "error": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "/stats/analysis/": {
      "post": {
        "summary": "Получить анализ результатов теста",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "test_id": {"type": "string"},
                "percentage": {"type": "number", "format": "float"},
                "time_spent": {"type": "integer"}
              },
              "required": ["test_id", "percentage", "time_spent"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Анализ результатов",
            "schema": {
              "type": "object",
              "properties": {
                "ok": {"type": "boolean"},
                "result": {"type": "object"}
              }
            }
          },
          "400": {
            "description": "Неверные параметры",
            "schema": {
              "type": "object",
              "properties": {
                "ok": {"type": "boolean", "example": false},
                "error": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "/stats/advanced-analysis/": {
      "post": {
        "summary": "Получить детальный анализ попытки",
        "description": "Возвращает детальный анализ по типам вопросов, регионам и сравнение с другими",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "attempt_id": {"type": "string", "description": "ID попытки"}
              },
              "required": ["attempt_id"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Детальный анализ",
            "schema": {
              "type": "object",
              "properties": {
                "ok": {"type": "boolean"},
                "result": {"type": "object"}
              }
            }
          },
          "404": {
            "description": "Попытка не найдена",
            "schema": {
              "type": "object",
              "properties": {
                "ok": {"type": "boolean", "example": false},
                "error": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "/dev/create-test-data/": {
      "post": {
        "summary": "Создать тестовые данные",
        "description": "Создает набор тестовых попыток для отладки",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Тестовые данные созданы",
            "schema": {
              "type": "object",
              "properties": {
                "ok": {"type": "boolean"},
                "result": {"type": "object"}
              }
            }
          },
          "500": {
            "description": "Ошибка сервера",
            "schema": {
              "type": "object",
              "properties": {
                "ok": {"type": "boolean", "example": false},
                "error": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}