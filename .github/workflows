name: CI

on:
  pull_request:
    branches: [ "master" ]

jobs:
  test-and-lint:
    runs-on: ubuntu-latest
    steps:
      - name: Закачка кода на ранер
        uses: actions/checkout@v4
      - name: Устанавливаем Гоу
        uses: actions/setup-go@v5
        with:
          go-version: '1.25'
          cache: true
      - name: Скачиваем зависимости
        run: go mod download
      - name: Запускаем проверки
        run: make test lint
